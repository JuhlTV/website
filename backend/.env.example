PORT=4000
NODE_ENV=development

# Lokale Entwicklung:
MONGODB_URI=mongodb://127.0.0.1:27017/feuerwehr_checkliste

# Railway Production (mit echten Credentials):
# MONGO_URL=mongodb://mongo:iISlONxmmxqjlVenPiXEmiOFNEwMgMkh@mongodb.railway.internal:27017/feuerwehr_checkliste

# Railway Alternative (falls ein separater Service Name):
# MONGO_PRIVATE_URL=mongodb://mongo:iISlONxmmxqjlVenPiXEmiOFNEwMgMkh@mongodb.railway.internal:27017/feuerwehr_checkliste

# Alternative variables if no URI is provided:
# MONGO_HOST=127.0.0.1
# MONGO_PORT=27017
# MONGO_DB=feuerwehr_checkliste
# MONGO_USER=
# MONGO_PASSWORD=

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=12h

FRONTEND_ORIGIN=http://localhost:5173
# Production example:
# FRONTEND_ORIGIN=https://website-production-17fc.up.railway.app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your.gmail@gmail.com
