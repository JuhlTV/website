# Sheriff Department Website - Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus!
# Alle diese Variablen können über Railway Dashboard konfiguriert werden!

# Discord Bot Token
# Besorge dir einen Bot Token von: https://discord.com/developers/applications
DISCORD_TOKEN=dein_discord_bot_token_hier

# Discord Client ID
# Findest du unter: https://discord.com/developers/applications → Deine App → General Information
CLIENT_ID=deine_discord_client_id_hier

# Discord Client Secret
# Findest du unter: https://discord.com/developers/applications → Deine App → OAuth2
CLIENT_SECRET=dein_discord_client_secret_hier

# Discord Target User ID
# Das ist die User ID von dem Person, die die DMs erhalten soll
# Wie man die ID findet: https://support.discord.com/hc/en-us/articles/206346498
DISCORD_TARGET_USER_ID=deine_discord_user_id_hier

# Public URL (für Railway Deployment)
# Beispiel: https://dein-app.railway.app
PUBLIC_URL=http://localhost:3000

# Server Port
PORT=3000

# Environment (production für Railway, development für lokal)
NODE_ENV=production
